{
  "name": "@aliou/pi-toolchain",
  "version": "0.9.1",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aliou/pi-toolchain"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "toolchain"
  ],
  "pi": {
    "extensions": [
      "./extensions/toolchain/index.ts"
    ],
    "video": "https://assets.aliou.me/github/aliou/pi-toolchain/demo.mp4"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "extensions",
    "README.md",
    "!src/**/*.test.ts",
    "!extensions/**/*.test.ts"
  ],
  "type": "module",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@aliou/pi-utils-settings": "^0.17.0",
    "@aliou/sh": "^0.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@aliou/biome-plugins": "^0.10.0",
    "@biomejs/biome": "^2.4.16",
    "@changesets/cli": "^2.31.0",
    "@earendil-works/pi-coding-agent": "0.79.9",
    "@earendil-works/pi-tui": "0.79.9",
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@earendil-works/pi-ai": "$@earendil-works/pi-coding-agent",
      "@earendil-works/pi-tui": "$@earendil-works/pi-coding-agent"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome check --write",
    "check:lockfile": "pnpm install --frozen-lockfile --ignore-scripts",
    "prepare": "[ -d .git ] && husky || true",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm changeset publish"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  }
}
